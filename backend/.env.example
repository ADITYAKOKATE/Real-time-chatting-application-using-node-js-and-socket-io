PORT=5000
MONGO_URI=mongodb://localhost:27017/slackclone
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=your_super_secret_key_change_this
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
SERVER_ID=server-1
NODE_ENV=development

# AWS S3 (Leave blank for local disk storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Web Push VAPID (Generate with: node generate_keys.js)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com
