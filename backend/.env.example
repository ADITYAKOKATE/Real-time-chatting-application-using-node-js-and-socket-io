PORT=5000
MONGO_URI=mongodb://localhost:27017/slackclone
REDIS_URL=redis://localhost:6379
JWT_SECRET=your_super_secret_key_change_this
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
SERVER_ID=server-1

# AWS S3 (Phase 4 - leave blank to use local disk fallback)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Web Push VAPID (Phase 5 - generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com
